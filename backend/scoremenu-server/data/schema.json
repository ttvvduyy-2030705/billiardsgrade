{
  "schemaVersion": "scoremenu_backend_schema_v1_batch25",
  "engine": "json-file-mvp",
  "tables": {
    "restaurants": {
      "primaryKey": "id",
      "required": [
        "id",
        "name",
        "createdAt",
        "updatedAt"
      ],
      "indexes": [
        "ownerId",
        "status"
      ]
    },
    "branches": {
      "primaryKey": "id",
      "required": [
        "id",
        "restaurantId",
        "name",
        "createdAt",
        "updatedAt"
      ],
      "indexes": [
        "restaurantId"
      ]
    },
    "tables": {
      "primaryKey": "id",
      "required": [
        "id",
        "restaurantId",
        "tableNumber",
        "qrCodeToken",
        "createdAt",
        "updatedAt"
      ],
      "indexes": [
        "restaurantId",
        "branchId",
        "qrCodeToken"
      ]
    },
    "categories": {
      "primaryKey": "id",
      "required": [
        "id",
        "restaurantId",
        "name",
        "createdAt",
        "updatedAt"
      ],
      "indexes": [
        "restaurantId",
        "sortOrder"
      ]
    },
    "items": {
      "primaryKey": "id",
      "required": [
        "id",
        "restaurantId",
        "categoryId",
        "name",
        "price",
        "createdAt",
        "updatedAt"
      ],
      "indexes": [
        "restaurantId",
        "categoryId",
        "status"
      ]
    },
    "orders": {
      "primaryKey": "id",
      "required": [
        "id",
        "restaurantId",
        "tableNumber",
        "items",
        "total",
        "orderStatus",
        "paymentStatus",
        "createdAt",
        "updatedAt"
      ],
      "indexes": [
        "restaurantId",
        "branchId",
        "tableId",
        "billSessionId",
        "guestSessionId",
        "orderStatus",
        "paymentStatus",
        "createdAt",
        "migratedBillSessionId"
      ]
    },
    "adminUsers": {
      "primaryKey": "id",
      "required": [
        "id",
        "username",
        "password",
        "role",
        "restaurantIds",
        "activeRestaurantId",
        "createdAt",
        "updatedAt"
      ],
      "indexes": [
        "username",
        "role",
        "restaurantIds"
      ]
    },
    "carts": {
      "primaryKey": "scopeKey",
      "required": [
        "restaurantId",
        "tableNumber",
        "items"
      ],
      "indexes": [
        "restaurantId",
        "branchId",
        "tableId"
      ]
    },
    "billSessions": {
      "primaryKey": "id",
      "required": [
        "id",
        "restaurantId",
        "tableNumber",
        "status",
        "orderIds",
        "subtotal",
        "total",
        "openedAt",
        "createdAt",
        "updatedAt"
      ],
      "indexes": [
        "restaurantId",
        "branchId",
        "tableId",
        "guestSessionId",
        "status",
        "openedAt",
        "updatedAt",
        "tableChangeLogs",
        "paymentMethod",
        "paymentRequestedAt",
        "paidAt",
        "closedAt",
        "migratedFromLegacyOrders",
        "migrationBatch",
        "source"
      ]
    },
    "auditLogs": {
      "primaryKey": "id",
      "required": [
        "id",
        "at",
        "action"
      ],
      "indexes": [
        "restaurantId",
        "branchId",
        "action",
        "targetId",
        "at"
      ]
    },
    "publicOrderRateLimits": {
      "primaryKey": "key",
      "required": [
        "key",
        "guestSessionId",
        "restaurantId",
        "orderWindowStartedAt",
        "orderCount",
        "errorWindowStartedAt",
        "errorCount",
        "createdAt",
        "updatedAt"
      ],
      "indexes": [
        "guestSessionId",
        "qrHash",
        "restaurantId",
        "branchId",
        "blockedUntil",
        "updatedAt"
      ]
    }
  },
  "foreignKeys": [
    "branches.restaurantId -> restaurants.id",
    "tables.restaurantId -> restaurants.id",
    "tables.branchId -> branches.id",
    "categories.restaurantId -> restaurants.id",
    "items.restaurantId -> restaurants.id",
    "items.categoryId -> categories.id",
    "orders.restaurantId -> restaurants.id",
    "orders.branchId -> branches.id",
    "orders.tableId -> tables.id",
    "billSessions.restaurantId -> restaurants.id",
    "billSessions.branchId -> branches.id",
    "billSessions.tableId -> tables.id",
    "orders.billSessionId -> billSessions.id",
    "auditLogs.restaurantId -> restaurants.id",
    "auditLogs.branchId -> branches.id"
  ],
  "events": {
    "billSession": [
      "billOpened",
      "orderAdded",
      "billClosed",
      "tableChanged",
      "abuseDetected"
    ]
  },
  "batch24": {
    "demoSeed": "Reset/demo database includes open BillSession examples for APlus and Haidilao with orderIds populated.",
    "legacyOrderMigration": "Orders without billSessionId are grouped by restaurant/branch/table/guest session into migrated BillSessions on backend load.",
    "modeParity": "local and dev-api both expose BillSession/TableBill behaviour; API mode must fail loudly when baseUrl is missing."
  },
  "batch25": {
    "acceptanceTests": "scripts/scoremenu-e2e-smoke.js covers first order, locked table, cumulative bill, admin bill dashboard, staff table transfer, paid/closed blocking, and restaurant/branch isolation.",
    "reportSeverity": "Acceptance script prints blocker/major/minor counts and fails the process when any check fails.",
    "demoReadiness": "All blocker checks must pass before restaurant demo."
  },
  "migrations": [
    "batch24_legacy_orders_to_bill_sessions"
  ]
}
