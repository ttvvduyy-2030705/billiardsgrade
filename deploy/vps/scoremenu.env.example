# ScoreMenu backend production env for VPS
# Copy to /etc/scoremenu/scoremenu.env and edit values.
NODE_ENV=production
SCOREMENU_HOST=127.0.0.1
SCOREMENU_PORT=4012

# Keep database/uploads outside the app folder so redeploy will not erase data.
SCOREMENU_DB_FILE=/var/lib/scoremenu/db.json
SCOREMENU_UPLOAD_DIR=/var/lib/scoremenu/uploads

# Change this before production. Generate with:
# openssl rand -hex 32
SCOREMENU_TOKEN_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32
SCOREMENU_TOKEN_TTL_MS=86400000

# Keep auth guard enabled in production.
SCOREMENU_AUTH_GUARD=1

# Upload / request limits
SCOREMENU_MAX_BODY_BYTES=12582912
SCOREMENU_MAX_IMAGE_BYTES=6291456

# Public order abuse guard
SCOREMENU_PUBLIC_ORDER_RATE_LIMIT_WINDOW_MS=60000
SCOREMENU_PUBLIC_ORDER_RATE_LIMIT_MAX=8
SCOREMENU_PUBLIC_ORDER_ERROR_LIMIT_WINDOW_MS=300000
SCOREMENU_PUBLIC_ORDER_ERROR_LIMIT_MAX=5
SCOREMENU_PUBLIC_ORDER_BLOCK_MS=300000
